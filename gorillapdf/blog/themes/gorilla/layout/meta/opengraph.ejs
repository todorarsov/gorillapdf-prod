<%  
  var ogi; 
  if (page.opengraphimage) {
    ogi = page.opengraphimage;
  } else if(config.opengraphimage) {
    ogi = config.opengraphimage;
  } else {
    ogi = 'images/broken-person.png';
  }
  ogi = 'https://gorillapdf.com' + url_for(ogi);
%>

  <meta property="og:locale" content="<%= config.language || "en" %>">
  <meta property="og:title" content="<%= title || config.title %>">
<% if (is_post()) {%>
  <meta property="og:type" content="article">
<% } %>
<% if (page.excerpt) {%>
  <meta property="og:description" content="<%= description || config.description %>">
<% } %>
  <meta property="og:url" content="<%= page.permalink %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:image" content="<%= ogi %>">

