    <span data-l10n-id="cursor_text_select_tool_label"><%=root.services.pdfreader.textSelectionTool%></span>
    </button>
    <button id="cursorHandTool" class="secondaryToolbarButton handTool" title="<%=root.services.pdfreader.handToolText%>" tabindex="61" data-l10n-id="cursor_hand_tool">
    <span data-l10n-id="cursor_hand_tool_label"><%=root.services.pdfreader.handTool%></span>
    </button>
    <div class="horizontalToolbarSeparator"></div>
    <button id="scrollVertical" class="secondaryToolbarButton scrollModeButtons scrollVertical toggled" title="<%=root.services.pdfreader.verticalScrollingText%>" tabindex="62" data-l10n-id="scroll_vertical">
    <span data-l10n-id="scroll_vertical_label"><%=root.services.pdfreader.verticalScrolling%></span>
    </button>
    <button id="scrollHorizontal" class="secondaryToolbarButton scrollModeButtons scrollHorizontal" title="<%=root.services.pdfreader.horizontalScrollingText%>" tabindex="63" data-l10n-id="scroll_horizontal">
    <span data-l10n-id="scroll_horizontal_label"><%=root.services.pdfreader.horizontalScrolling%></span>
    </button>
    <button id="scrollWrapped" class="secondaryToolbarButton scrollModeButtons scrollWrapped" title="<%=root.services.pdfreader.verticalScrollingText%>" tabindex="64" data-l10n-id="scroll_wrapped">
    <span data-l10n-id="scroll_wrapped_label"><%=root.services.pdfreader.wrappedScrolling%></span>
    </button>
    <div class="horizontalToolbarSeparator scrollModeButtons"></div>
    <button id="spreadNone" class="secondaryToolbarButton spreadModeButtons spreadNone toggled" title="<%=root.services.pdfreader.noSpreadsText%>" tabindex="65" data-l10n-id="spread_none">
