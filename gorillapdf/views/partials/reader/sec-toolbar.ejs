<div id="secondaryToolbar" class="secondaryToolbar hidden doorHangerRight">
    <div id="secondaryToolbarButtonContainer">
    <button id="secondaryPresentationMode" class="secondaryToolbarButton presentationMode visibleLargeView" title="<%=root.services.pdfreader.presentationMode%>" tabindex="51" data-l10n-id="presentation_mode">
    <span data-l10n-id="presentation_mode_label"><%=root.services.pdfreader.presentationMode%></span>
    </button>
    <button id="secondaryOpenFile" class="secondaryToolbarButton openFile visibleLargeView" title="<%=root.services.pdfreader.openFile%>" tabindex="52" data-l10n-id="open_file">
    <span data-l10n-id="open_file_label"><%=root.services.pdfreader.open%></span>
    </button>
    <button id="secondaryPrint" class="secondaryToolbarButton print visibleMediumView" title="<%=root.services.pdfreader.print%>" tabindex="53" data-l10n-id="print">
    <span data-l10n-id="print_label"><%=root.services.pdfreader.print%></span>
    </button>
    <button id="secondaryDownload" class="secondaryToolbarButton download visibleMediumView" title="<%=root.services.pdfreader.download%>" tabindex="54" data-l10n-id="download">
    <span data-l10n-id="download_label"><%=root.services.pdfreader.download%></span>
    </button>
    <a href="#" id="secondaryViewBookmark" class="secondaryToolbarButton bookmark visibleSmallView" title="<%=root.services.pdfreader.currentViewText%>" tabindex="55" data-l10n-id="bookmark">
    <span data-l10n-id="bookmark_label"><%=root.services.pdfreader.currentView%></span>
    </a>
    <div class="horizontalToolbarSeparator visibleLargeView"></div>
    <button id="firstPage" class="secondaryToolbarButton firstPage" title="<%=root.services.pdfreader.goToFirstPage%>" tabindex="56" data-l10n-id="first_page">
