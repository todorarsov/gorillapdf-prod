    </button>
    <button id="spreadEven" class="secondaryToolbarButton spreadModeButtons spreadEven" title="<%=root.services.pdfreader.evenSpreadsText%>" tabindex="67" data-l10n-id="spread_even">
    <span data-l10n-id="spread_even_label"><%=root.services.pdfreader.evenSpreads%></span>
    </button>
    <div class="horizontalToolbarSeparator spreadModeButtons"></div>
    <button id="documentProperties" class="secondaryToolbarButton documentProperties" title="<%=root.services.pdfreader.documentProperties%>" tabindex="68" data-l10n-id="document_properties">
    <span data-l10n-id="document_properties_label"><%=root.services.pdfreader.documentProperties%></span>
    </button>
    </div>
    </div> 