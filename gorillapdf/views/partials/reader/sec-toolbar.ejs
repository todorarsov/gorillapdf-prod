    </button>
    <button id="lastPage" class="secondaryToolbarButton lastPage" title="<%=root.services.pdfreader.goToLastPage%>" tabindex="57" data-l10n-id="last_page">
    <span data-l10n-id="last_page_label"><%=root.services.pdfreader.goToLastPage%></span>
    </button>
    <div class="horizontalToolbarSeparator"></div>
    <button id="pageRotateCw" class="secondaryToolbarButton rotateCw" title="<%=root.services.pdfreader.rotateClockwise%>" tabindex="58" data-l10n-id="page_rotate_cw">
    <span data-l10n-id="page_rotate_cw_label"><%=root.services.pdfreader.rotateClockwise%></span>
    </button>
    <button id="pageRotateCcw" class="secondaryToolbarButton rotateCcw" title="<%=root.services.pdfreader.rotateCounterClockwise%>" tabindex="59" data-l10n-id="page_rotate_ccw">
    <span data-l10n-id="page_rotate_ccw_label"><%=root.services.pdfreader.rotateCounterClockwise%></span>
    </button>
    <div class="horizontalToolbarSeparator"></div>
