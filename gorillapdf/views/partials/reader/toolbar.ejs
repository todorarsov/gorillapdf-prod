<div class="toolbar">
    <div id="toolbarContainer">
    <div id="toolbarViewer">
    <div id="toolbarViewerLeft">
     <span>
        <a href="/">
          <img alt="GorillaPDF Logo" class="custom-logo-small" title="GorillaPDF" src="/img/gorillapdf-logo.png" />
        </a>
         <input type="button" value="<%=root.services.pdfreader.close%>" class="btn btn-danger" onclick="location.reload()" />
     </span>       
    <button id="sidebarToggle" class="toolbarButton" title="Toggle Sidebar" tabindex="11" data-l10n-id="toggle_sidebar">
    <span data-l10n-id="toggle_sidebar_label"><%=root.services.pdfreader.toggleSidebar%></span>
    </button>
    <div class="toolbarButtonSpacer"></div>
    <button id="viewFind" class="toolbarButton" title="Find in Document" tabindex="12" data-l10n-id="findbar">
    <span data-l10n-id="findbar_label"><%=root.services.pdfreader.find%></span>
    </button>
    <div class="splitToolbarButton hiddenSmallView">
    <button class="toolbarButton pageUp" title="Previous Page" id="previous" tabindex="13" data-l10n-id="previous">
    <span data-l10n-id="previous_label"><%=root.services.pdfreader.previous%></span>
    </button>
    <div class="splitToolbarButtonSeparator"></div>
    <button class="toolbarButton pageDown" title="Next Page" id="next" tabindex="14" data-l10n-id="next">
    <span data-l10n-id="next_label"><%=root.services.pdfreader.next%></span>
    </button>
    </div>
    <input type="number" min="1" step="1" id="pageNumber" class="toolbarField pageNumber" title="<%=root.services.pdfreader.page%>" value="1" size="4" min="1" tabindex="15" data-l10n-id="page">
    <span id="numPages" class="toolbarLabel"></span>
    </div>
    <div id="toolbarViewerRight">
    <button id="presentationMode" class="toolbarButton presentationMode hiddenLargeView" title="<%=root.services.pdfreader.switchToPresentation%>" tabindex="31" data-l10n-id="presentation_mode">
    <span data-l10n-id="presentation_mode_label"><%=root.services.pdfreader.presentationMode%></span>
    </button>
    <button id="openFile" class="toolbarButton openFile hiddenLargeView" title="<%=root.services.pdfreader.openFile%>" tabindex="32" data-l10n-id="open_file">
    <span data-l10n-id="open_file_label"><%=root.services.pdfreader.open%></span>
    </button>
    <button id="print" class="toolbarButton print hiddenMediumView" title="<%=root.services.pdfreader.print%>" tabindex="33" data-l10n-id="print">
    <span data-l10n-id="print_label"><%=root.services.pdfreader.print%></span>
    </button>
    <button id="download" class="toolbarButton download hiddenMediumView" title="<%=root.services.pdfreader.download%>" tabindex="34" data-l10n-id="download">
    <span data-l10n-id="download_label"><%=root.services.pdfreader.download%></span>
    </button>
    <a href="#" id="viewBookmark" class="toolbarButton bookmark hiddenSmallView" title="<%=root.services.pdfreader.currentViewCopy%>" tabindex="35" data-l10n-id="bookmark">
    <span data-l10n-id="bookmark_label"><%=root.services.pdfreader.currentView%></span>
    </a>
    <div class="verticalToolbarSeparator hiddenSmallView"></div>
    <button id="secondaryToolbarToggle" class="toolbarButton" title="<%=root.services.pdfreader.tools%>" tabindex="36" data-l10n-id="tools">
    <span data-l10n-id="tools_label"><%=root.services.pdfreader.tools%></span>
    </button>
    </div>
    <div id="toolbarViewerMiddle">
    <div class="splitToolbarButton">
    <button id="zoomOut" class="toolbarButton zoomOut" title="<%=root.services.pdfreader.zoomOut%>" tabindex="21" data-l10n-id="zoom_out">
    <span data-l10n-id="zoom_out_label"><%=root.services.pdfreader.zoomOut%></span>
    </button>
    <div class="splitToolbarButtonSeparator"></div>
    <button id="zoomIn" class="toolbarButton zoomIn" title="<%=root.services.pdfreader.zoomIn%>" tabindex="22" data-l10n-id="zoom_in">
    <span data-l10n-id="zoom_in_label"><%=root.services.pdfreader.zoomIn%></span>
    </button>
    </div>
    <span id="scaleSelectContainer" class="dropdownToolbarButton">
    <select id="scaleSelect" title="<%=root.services.pdfreader.zoom%>" tabindex="23" data-l10n-id="zoom">
    <option id="pageActualOption" title="" value="page-actual" data-l10n-id="page_scale_actual"><%=root.services.pdfreader.actualSize%></option>
    <option id="pageFitOption" title="" value="page-fit" data-l10n-id="page_scale_fit"><%=root.services.pdfreader.pageFit%></option>
    <option id="pageWidthOption" title="" value="page-width" data-l10n-id="page_scale_width"><%=root.services.pdfreader.pageWidth%></option>
    <option id="customScaleOption" title="" value="custom" disabled="disabled" hidden="true"></option>
    <option title="" value="0.5" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 50 }'>50%</option>
    <option title="" value="0.75" data-l10n-id="page_scale_percent" selected="selected" data-l10n-args='{ "scale": 75 }'>75%</option>
    <option title="" value="1" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 100 }'>100%</option>
    <option title="" value="1.25" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 125 }'>125%</option>
    <option title="" value="1.5" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 150 }'>150%</option>
    <option title="" value="2" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 200 }'>200%</option>
    <option title="" value="3" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 300 }'>300%</option>
    <option title="" value="4" data-l10n-id="page_scale_percent" data-l10n-args='{ "scale": 400 }'>400%</option>
    <!-- <option id="pageAutoOption" title="" value="auto"  data-l10n-id="page_scale_auto">Automatic Zoom</option> -->
    </select>
    </span>
    </div>
    </div>
    <div id="loadingBar">
    <div class="progress">
    <div class="glimmer">
    </div>
    </div>
    </div>
    </div>
    </div>