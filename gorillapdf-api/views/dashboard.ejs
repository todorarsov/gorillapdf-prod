<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <!-- Add your CSS styling here -->
    <style>
        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            border: 1px solid #dddddd;
            text-align: left;
            padding: 8px;
        }

        th {
            background-color: #f2f2f2;
        }
        /* Add your CSS styles here */
.even {
    background-color: #f2f2f2; /* Light gray for even rows */
}

.odd {
    background-color: #ffffff; /* White for odd rows */
}

.high-percentage {
    color: green; /* Green text color for high percentages */
}

.low-percentage {
    color: red; /* Red text color for low percentages */
}
    </style>
</head>
<body>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Service</th>
                <th>File Count</th>
                <th>Percentage</th>
            </tr>
        </thead>
        <tbody>
            <% const totalFiles = Object.values(statsData).reduce((sum, count) => sum + count, 0); %>
            <% const sortedStats = Object.entries(statsData).sort((a, b) => b[1] - a[1]); %>
            <% sortedStats.forEach((entry, index) => { %>
                <tr class="<%= index % 2 === 0 ? 'even' : 'odd' %>">
                    <td><%= index + 1 %></td>
                    <td><%= entry[0] %></td>
                    <td><%= entry[1] %></td>
                    <td class="<%= entry[1] / totalFiles >= 0.5 ? 'high-percentage' : 'low-percentage' %>">
                        <%= ((entry[1] / totalFiles) * 100).toFixed(2) %> %
                    </td>
                </tr>
            <% }); %>
            <tr class="total-row">
                <td colspan="2">Total Files:</td>
                <td><%= totalFiles %></td>
                <td></td>
            </tr>
        </tbody>
    </table> 
    
</body>
</html>